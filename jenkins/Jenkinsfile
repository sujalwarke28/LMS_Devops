pipeline {
    agent any

    environment {
        AWS_REGION          = 'ap-south-1'
        AWS_ACCOUNT_ID      = credentials('aws-account-id')
        ECR_REGISTRY        = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
        BACKEND_IMAGE       = "${ECR_REGISTRY}/lms-backend"
        FRONTEND_IMAGE      = "${ECR_REGISTRY}/lms-frontend"
        KUBE_NAMESPACE      = 'lms'
        IMAGE_TAG           = "${GIT_COMMIT[0..7]}"
        SLACK_CHANNEL       = '#devops-alerts'
        PATH                = "/opt/homebrew/bin:/usr/local/bin:${env.PATH}"
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timestamps()
        timeout(time: 45, unit: 'MINUTES')
    }

    stages {

        // ── 1. Checkout ─────────────────────────────────────────
        stage('Checkout') {
            steps {
                checkout scm
                echo "✅ Checked out branch: ${env.BRANCH_NAME} | Commit: ${env.GIT_COMMIT}"
            }
        }

        // ── 2. Lint & Test Backend ───────────────────────────────
        stage('Backend: Install & Test') {
            steps {
                dir('backend') {
                    sh 'npm ci'
                    sh 'npm run lint || true'
                    sh 'npm test -- --passWithNoTests'
                }
            }
            post {
                always {
                    publishHTML([
                        allowMissing: true,
                        alwaysLinkToLastBuild: false,
                        keepAll: true,
                        reportDir: 'backend/coverage',
                        reportFiles: 'index.html',
                        reportName: 'Backend Coverage'
                    ])
                }
            }
        }

        // ── 3. Lint Frontend ─────────────────────────────────────
        stage('Frontend: Install') {
            steps {
                dir('frontend') {
                    sh 'npm ci'
                }
            }
        }

        // ── 4. Docker Build ──────────────────────────────────────
        stage('Docker Build') {
            parallel {
                stage('Build Backend Image') {
                    steps {
                        sh """
                            docker build \
                              -t ${BACKEND_IMAGE}:${IMAGE_TAG} \
                              -t ${BACKEND_IMAGE}:latest \
                              ./backend
                        """
                    }
                }
                stage('Build Frontend Image') {
                    steps {
                        withCredentials([
                            string(credentialsId: 'vite-firebase-api-key', variable: 'VITE_FIREBASE_API_KEY'),
                            string(credentialsId: 'vite-firebase-auth-domain', variable: 'VITE_FIREBASE_AUTH_DOMAIN'),
                            string(credentialsId: 'vite-firebase-project-id', variable: 'VITE_FIREBASE_PROJECT_ID'),
                            string(credentialsId: 'vite-firebase-storage-bucket', variable: 'VITE_FIREBASE_STORAGE_BUCKET'),
                            string(credentialsId: 'vite-firebase-sender-id', variable: 'VITE_FIREBASE_MESSAGING_SENDER_ID'),
                            string(credentialsId: 'vite-firebase-app-id', variable: 'VITE_FIREBASE_APP_ID'),
                        ]) {
                            sh """
                                docker build \
                                  --build-arg VITE_FIREBASE_API_KEY=${VITE_FIREBASE_API_KEY} \
                                  --build-arg VITE_FIREBASE_AUTH_DOMAIN=${VITE_FIREBASE_AUTH_DOMAIN} \
                                  --build-arg VITE_FIREBASE_PROJECT_ID=${VITE_FIREBASE_PROJECT_ID} \
                                  --build-arg VITE_FIREBASE_STORAGE_BUCKET=${VITE_FIREBASE_STORAGE_BUCKET} \
                                  --build-arg VITE_FIREBASE_MESSAGING_SENDER_ID=${VITE_FIREBASE_MESSAGING_SENDER_ID} \
                                  --build-arg VITE_FIREBASE_APP_ID=${VITE_FIREBASE_APP_ID} \
                                  --build-arg VITE_API_BASE_URL=/api/v1 \
                                  -t ${FRONTEND_IMAGE}:${IMAGE_TAG} \
                                  -t ${FRONTEND_IMAGE}:latest \
                                  ./frontend
                            """
                        }
                    }
                }
            }
        }

        // ── 5. Push to ECR ───────────────────────────────────────
        stage('Push to ECR') {
            when {
                anyOf {
                    branch 'main'
                    branch 'develop'
                }
            }
            steps {
                withCredentials([[$class: 'AmazonWebServicesCredentialsBinding', credentialsId: 'aws-credentials']]) {
                    sh """
                        aws ecr get-login-password --region ${AWS_REGION} | \
                          docker login --username AWS --password-stdin ${ECR_REGISTRY}
                        docker push ${BACKEND_IMAGE}:${IMAGE_TAG}
                        docker push ${BACKEND_IMAGE}:latest
                        docker push ${FRONTEND_IMAGE}:${IMAGE_TAG}
                        docker push ${FRONTEND_IMAGE}:latest
                    """
                }
            }
        }

        // ── 6. Deploy to Kubernetes ──────────────────────────────
        stage('Deploy to EKS') {
            when {
                branch 'main'
            }
            steps {
                withCredentials([[$class: 'AmazonWebServicesCredentialsBinding', credentialsId: 'aws-credentials']]) {
                    sh """
                        aws eks update-kubeconfig --region ${AWS_REGION} --name lms-eks-cluster-prod
                        kubectl apply -f k8s/namespace.yaml
                        kubectl apply -f k8s/backend/ -n ${KUBE_NAMESPACE}
                        kubectl apply -f k8s/frontend/ -n ${KUBE_NAMESPACE}
                        kubectl apply -f k8s/ingress/ -n ${KUBE_NAMESPACE}
                        kubectl set image deployment/lms-backend lms-backend=${BACKEND_IMAGE}:${IMAGE_TAG} -n ${KUBE_NAMESPACE}
                        kubectl set image deployment/lms-frontend lms-frontend=${FRONTEND_IMAGE}:${IMAGE_TAG} -n ${KUBE_NAMESPACE}
                        kubectl rollout status deployment/lms-backend -n ${KUBE_NAMESPACE} --timeout=300s
                        kubectl rollout status deployment/lms-frontend -n ${KUBE_NAMESPACE} --timeout=300s
                    """
                }
            }
        }

        // ── 7. Smoke Test ────────────────────────────────────────
        stage('Smoke Test') {
            when {
                branch 'main'
            }
            steps {
                sh '''
                    sleep 15
                    INGRESS_IP=$(kubectl get svc -n lms -o jsonpath="{.items[?(@.spec.type=='LoadBalancer')].status.loadBalancer.ingress[0].hostname}")
                    curl -sf "http://${INGRESS_IP}/health" || echo "Warning: Health check not yet available"
                '''
            }
        }

    } // end stages

    post {
        success {
            echo "✅ Pipeline completed successfully for ${env.BRANCH_NAME}:${IMAGE_TAG}"
        }
        failure {
            echo "❌ Pipeline FAILED for ${env.BRANCH_NAME}:${IMAGE_TAG}"
        }
        always {
            sh 'docker system prune -f --volumes || true'
            cleanWs()
        }
    }
}
